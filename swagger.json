  "components": {
    "schemas": {
      "ElectricalPowerStation": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "activeUnitsCount": {
            "type": "integer",
            "format": "int32"
          },
          "unitType": {
            "type": "string",
            "nullable": true
          },
          "launchDate": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "ElectricalPowerStationCreateDTO": {
        "required": [
          "activeUnitsCount",
          "launchDate",
          "name",
          "unitType"
        ],
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 200,
            "minLength": 0,
            "type": "string"
          },
          "unitType": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "activeUnitsCount": {
            "maximum": 30,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "launchDate": {
            "type": "string",
            "format": "date"
          }
        },
        "additionalProperties": false
      },
      "ElectricalPowerStationUpdateDTO": {
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 200,
            "minLength": 0,
            "type": "string",
            "nullable": true
          },
          "unitType": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string",
            "nullable": true
          },
          "activeUnitsCount": {
            "maximum": 30,
            "minimum": 1,
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "launchDate": {
            "type": "string",
            "format": "date",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ElectricalUnitPassport": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "unitType": {
            "type": "string",
            "nullable": true
          },
          "engineType": {
            "type": "string",
            "nullable": true
          },
          "ratedPower": {
            "type": "integer",
            "format": "int32"
          },
          "standartPower": {
            "type": "integer",
            "format": "int32"
          },
          "consumptionNorm": {
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "ElectricalUnitPassportCreateDTO": {
        "required": [
          "consumptionNorm",
          "engineType",
          "ratedPower",
          "standartPower",
          "unitType"
        ],
        "type": "object",
        "properties": {
          "unitType": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "engineType": {
            "minLength": 1,
            "pattern": "^(Поршневой|Газотурбинный)$",
            "type": "string"
          },
          "ratedPower": {
            "maximum": 100000,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "standartPower": {
            "maximum": 100000,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "consumptionNorm": {
            "maximum": 1000,
            "minimum": 0.1,
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "ElectricalUnitPassportUpdateDTO": {
        "type": "object",
        "properties": {
          "unitType": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string",
            "nullable": true
          },
          "engineType": {
            "pattern": "^(Поршневой|Газотурбинный)$",
            "type": "string",
            "nullable": true
          },
          "ratedPower": {
            "maximum": 100000,
            "minimum": 1,
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "standartPower": {
            "maximum": 100000,
            "minimum": 1,
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "consumptionNorm": {
            "maximum": 1000,
            "minimum": 0.1,
            "type": "number",
            "format": "double",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ElectricityCalculationRequestDTO": {
        "required": [
          "lowerHeatingValue",
          "operatingHours",
          "outsideTemperature",
          "stationId",
          "unitPowerPercentage"
        ],
        "type": "object",
        "properties": {
          "stationId": {
            "type": "integer",
            "format": "int32"
          },
          "outsideTemperature": {
            "maximum": 40,
            "minimum": -30,
            "type": "number",
            "format": "double"
          },
          "operatingHours": {
            "maximum": 100000,
            "minimum": 0,
            "type": "number",
            "format": "double"
          },
          "unitPowerPercentage": {
            "maximum": 100,
            "minimum": 20,
            "type": "number",
            "format": "double"
          },
          "lowerHeatingValue": {
            "maximum": 10000,
            "minimum": 7000,
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "ElectricityCalculationResponseDTO": {
        "type": "object",
        "properties": {
          "gasConsumption": {
            "type": "number",
            "format": "double"
          },
          "unit": {
            "type": "string",
            "nullable": true
          },
          "calculationTime": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "LoginData": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
